ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
UPLOAD_TEMP_DIR=tmp/audio
MAX_UPLOAD_SIZE_MB=25
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# --- LLM provider (Milestone 5.1) ---------------------------------------
# Leave LLM_PROVIDER empty to run in metric-only mode (no reasoning or
# coaching output; POST /analyze still works for the four deterministic
# metrics). Set it to exactly one of: openai, anthropic, gemini, ollama.
LLM_PROVIDER=
LLM_MODEL=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
